{
  "name": "@vella/contract",
  "version": "1.0.0",
  "description": "Shared contract between Vella MOBILE and Vella-Control - single source of truth for entitlements, pricing, and features",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "types": "./dist/types.d.ts"
    },
    "./entitlements": {
      "types": "./dist/entitlements.d.ts"
    },
    "./pricing": {
      "types": "./dist/pricing.d.ts"
    },
    "./features": {
      "types": "./dist/features.d.ts"
    }
  }
}
