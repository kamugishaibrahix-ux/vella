# SECURITY: Prevent accidental commit of secrets. Never commit .env files.
.env
.env.*
.env.local
.env.*.local
.env.development
.env.production
.env.test
*.local

# Known secret / credential files
*.pem
*.key
credentials.json
service-account*.json

# Dependencies
node_modules/

# Build outputs
.next/
out/
dist/
build/

# IDE / OS
.idea/
.vscode/
.DS_Store
*.log

# TypeScript build cache
*.tsbuildinfo

# Supabase temp folders
supabase/.temp/
MOBILE/supabase/.temp/

# Debug output files
*_output.txt
tsc_errors*.txt
db_push*.txt
db_reset*.txt
schema_dump.sql
null

# Operation logs
push_attempt.log
push_full.log
repairs.txt
file_tree.txt

# Allow compiled contract package
!packages/vella-contract/dist/
!packages/vella-contract/dist/**
