{
  "name": "MOBILE",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node ../scripts/verifyDataDesignRead.mjs --force-root || exit 1",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "check:supabase": "node ../scripts/scanSupabaseTables.mjs",
    "check:rls": "node ../scripts/auditRLSPolicies.mjs",
    "check:api": "node ../scripts/auditAPIRoutes.mjs",
    "check:security": "pnpm check:supabase && pnpm check:rls && pnpm check:api",
    "check:data": "node ../scripts/checkForbiddenPatterns.ts && node ../scripts/checkPhase0Lockdown.mjs && node scripts/checkNoServerTextColumns.mjs && pnpm check:supabase && pnpm test -- --run test/api/migrationAuditNoText.test.ts && eslint . --ext .ts,.tsx",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "precommit": "pnpm check:data"
  },
  "dependencies": {
    "@supabase/auth-helpers-nextjs": "^0.10.0",
    "@supabase/supabase-js": "^2.47.10",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.24",
    "ioredis": "^5.9.2",
    "lucide-react": "^0.460.0",
    "next": "14.2.7",
    "openai": "^6.9.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "stripe": "^16.8.0",
    "swr": "^2.3.6",
    "uuid": "^13.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.9",
    "@types/react-dom": "^18.3.3",
    "@types/uuid": "^11.0.0",
    "@vitest/ui": "^2.1.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.7",
    "eslint-plugin-data-safety": "file:./eslint-plugin-data-safety",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vitest": "^2.1.0"
  }
}
